## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.env

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
[Bb]in/
[Oo]bj/
*.pdb
*.exe
*.dll

# Visual Studio cache files
.vs/

# NuGet Packages
*.nupkg
**/[Pp]ackages/*

# Node.js
node_modules/

# VS Code
.vscode/frontend/node_modules/ 
frontend/dist/ 
